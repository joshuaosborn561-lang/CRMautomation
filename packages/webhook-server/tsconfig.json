{
    "compilerOptions": {
          "target": "ES2022",
          "module": "commonjs",
          "lib": ["ES2022"],
          "outDir": "./dist",
          "strict": false,
          "esModuleInterop": true,
          "skipLibCheck": true,
          "forceConsistentCasingInFileNames": true,
          "resolveJsonModule": true,
          "declaration": true,
          "noEmitOnError": false,
          "paths": {
                  "@crm-autopilot/shared": ["../shared/src"]
          }
    },
    "include": ["src/**/*", "../shared/src/**/*"],
    "exclude": ["node_modules", "dist"]
}
