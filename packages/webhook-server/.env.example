# Server
PORT=3000
NODE_ENV=development
REVIEW_MODE=true

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Attio CRM
ATTIO_API_KEY=your-attio-api-key
ATTIO_PIPELINE_ID=your-pipeline-id

# SmartLead
SMARTLEAD_API_KEY=your-smartlead-api-key
SMARTLEAD_WEBHOOK_SECRET=your-webhook-secret
SMARTLEAD_NURTURE_CAMPAIGN_ID=your-nurture-campaign-id

# HeyReach
HEYREACH_API_KEY=your-heyreach-api-key
HEYREACH_WEBHOOK_SECRET=your-webhook-secret

# Zoom (Server-to-Server OAuth)
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_WEBHOOK_SECRET_TOKEN=your-zoom-webhook-secret-token
ZOOM_WEBHOOK_VERIFICATION_TOKEN=your-zoom-verification-token

# Apollo.io (lead enrichment by phone number)
APOLLO_API_KEY=your-apollo-api-key

# Google Workspace / Gmail
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token
GMAIL_USER_EMAIL=you@yourdomain.com
GOOGLE_PUBSUB_TOPIC=projects/your-project/topics/gmail-push
